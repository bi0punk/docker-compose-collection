# ============================================================
# Grafana + Prometheus — Variables de entorno
# cp .env.example .env  →  edita antes de levantar
# ============================================================

# --- Versiones (pins explícitos) ---
PROMETHEUS_VERSION=v3.4.0
GRAFANA_VERSION=12.0.1

# --- Puertos del host ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# --- Credenciales Grafana ---
GRAFANA_ADMIN_USER=admin
# Generar: openssl rand -base64 16
GRAFANA_ADMIN_PASSWORD=C4mbia_esto_AHORA!

# --- Clave secreta Grafana (cookies/sessions) ---
# Generar: openssl rand -hex 32
GRAFANA_SECRET_KEY=cambia_esta_clave_secreta_ahora

# --- URL pública de Grafana (para links en alertas) ---
GRAFANA_ROOT_URL=http://localhost:3000

# --- Retención de métricas Prometheus ---
PROMETHEUS_RETENTION=15d

# --- Nivel de log Grafana (debug|info|warn|error) ---
GRAFANA_LOG_LEVEL=warn
