# ============================================================
# PostgreSQL — Variables de entorno
# cp .env.example .env  →  edita antes de levantar
# ============================================================

# --- Versión ---
POSTGRES_VERSION=16-alpine

# --- Puerto del host ---
POSTGRES_PORT=5432

# --- Credenciales (cámbiala antes del primer inicio) ---
POSTGRES_USER=app_user
# Generar: openssl rand -base64 16
POSTGRES_PASSWORD=C4mbia_esto_AHORA!
POSTGRES_DB=app_db

# --- Ajustes de rendimiento ---
# shared_buffers: ~25% de la RAM disponible para el contenedor
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_MAX_CONNECTIONS=100
# Logear queries que tarden más de X ms (0 = todas, -1 = deshabilitar)
POSTGRES_SLOW_QUERY_MS=500
