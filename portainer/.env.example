# --- Versión (pin explícito) ---
# Ver releases en: https://github.com/portainer/portainer/releases
PORTAINER_VERSION=2.27.4

# --- Puertos del host ---
PORTAINER_HTTP_PORT=9000
PORTAINER_HTTPS_PORT=9443
