# ============================================================
# n8n — Variables de entorno
# cp .env.example .env  →  edita antes de levantar
# ============================================================

# --- Versión (pin explícito) ---
# Ver tags en: https://hub.docker.com/r/n8nio/n8n/tags
N8N_VERSION=1.93.0

# --- Servidor ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http

# --- Clave de cifrado de credenciales (OBLIGATORIO) ---
# Generar: openssl rand -hex 32
# IMPORTANTE: si se pierde, las credenciales guardadas dejan de funcionar
N8N_ENCRYPTION_KEY=cambia_esta_clave_secreta_ahora

# --- URL pública para webhooks (si n8n es accesible desde internet) ---
# Ejemplo: https://n8n.tudominio.com/
WEBHOOK_URL=

# --- Métricas Prometheus ---
N8N_METRICS=false

# --- Retención de ejecuciones (días) ---
N8N_EXECUTIONS_RETENTION_DAYS=30

# --- Log level (debug|info|warn|error) ---
N8N_LOG_LEVEL=warn

# --- Zona horaria ---
N8N_TIMEZONE=America/Bogota
