# ============================================================
# GitLab CE — Variables de entorno
# cp .env.example .env  →  edita antes de levantar
# ============================================================

# --- URL pública ---
# Usar dominio real en producción: https://gitlab.tudominio.com
GITLAB_HOST=http://localhost:8080

# --- Puertos del host ---
GITLAB_SSH_PORT=8022
GITLAB_HTTP_PORT=8080
GITLAB_HTTPS_PORT=8443

# --- Credenciales iniciales (cámbiala antes del primer inicio) ---
GITLAB_ROOT_EMAIL=admin@example.com
# IMPORTANTE: mínimo 8 caracteres, GitLab valida la complejidad
GITLAB_ROOT_PASSWORD=C4mbia_esto_AHORA!

# --- Hostname del contenedor ---
GITLAB_HOSTNAME=gitlab

# --- Versión (pin explícito recomendado en prod) ---
# Ver tags en: https://hub.docker.com/r/gitlab/gitlab-ce/tags
GITLAB_VERSION=17.11.1-ce.0

# --- Zona horaria ---
GITLAB_TIMEZONE=America/Bogota
